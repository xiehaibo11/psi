[Unit]
Description=Finer PSI Backend (Jeecg System)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/psi/jeecg-boot
ExecStart=/root/psi/jeecg-boot/scripts/start-jeecg-system.sh
Restart=always
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
